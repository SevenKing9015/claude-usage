#!/usr/bin/env node
// Send a command to a running claude-usage-overlay over its control socket.
// Usage: overlayctl <toggle|cycle|op+|op-|login|refresh|quit>
const net = require('net')
const path = require('path')
const os = require('os')

const base = process.env.XDG_CONFIG_HOME || path.join(os.homedir(), '.config')
const sock = path.join(base, 'claude-usage-overlay', 'overlay.sock')
const msg = process.argv.slice(2).join(' ').trim()

if (!msg) {
  console.error('usage: overlayctl <toggle|cycle|op+|op-|login|refresh|quit>')
  process.exit(1)
}
const c = net.connect(sock, () => c.end(msg + '\n'))
c.on('error', e => { console.error('cannot reach overlay (is it running?):', e.message); process.exit(1) })
